{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": ["packages/**/*", "apps/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "**/dist/**", "packages/scripts/**/*"]
}