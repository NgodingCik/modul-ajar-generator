<div class="w-screen h-screen p-2">
  <div
    class="w-full h-full p-3 flex flex-col border-2 rounded-md border-mist-700 bg-mist-800"
  >
    <h1 class="text-2xl font-bold mb-4 text-white">
      Selamat Datang di
      <span class="bg-blue-500 px-2 py-1 rounded"><%= APP_NAME %></span>!
    </h1>

    <div class="flex-1 flex gap-3 overflow-auto">
      <div class="flex-2 overflow-auto p-2">
        <p class="text-lg text-gray-300 mb-6">
          Silakan lengkapi formulir di bawah ini untuk membuat RPP.
        </p>

        <form
          id="form-rpp"
          class="grid gap-4 md:grid-cols-2 bg-white/10 p-6 rounded-lg border border-gray-600 text-white"
        >
          <!-- Document Type Selection -->
          <div class="flex flex-col gap-2 mb-2 md:col-span-2">
            <label class="font-medium text-gray-200">Jenis Dokumen RPP</label>
            <div class="flex gap-4">
              <button
                type="button"
                id="btn_rpph"
                onclick="pilihTipeRPP('rpph')"
                class="flex-1 py-2 px-4 rounded font-semibold transition-colors bg-blue-500 text-white border border-blue-500 hover:bg-blue-600 focus:outline-none"
              >
                Pilih RPPH
              </button>
              <button
                type="button"
                id="btn_rppm"
                onclick="pilihTipeRPP('rppm')"
                class="flex-1 py-2 px-4 rounded font-semibold transition-colors bg-gray-700 text-gray-300 border border-gray-600 hover:bg-gray-600 focus:outline-none hover:cursor-not-allowed"
                disabled
              >
                Pilih RPPM
              </button>
            </div>
            <input type="hidden" id="tipe_rpp" name="tipe_rpp" value="rpph" />
          </div>

          <div class="flex flex-col gap-1">
            <label for="nama_pengajar" class="font-medium text-gray-200"
              >Nama Pengajar</label
            >
            <input
              type="text"
              id="nama_pengajar"
              name="nama_pengajar"
              placeholder="Masukkan nama pengajar"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="nama_sekolah" class="font-medium text-gray-200"
              >Nama Sekolah</label
            >
            <input
              type="text"
              id="nama_sekolah"
              name="nama_sekolah"
              placeholder="Masukkan nama sekolah"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="hari_tanggal" class="font-medium text-gray-200"
              >Hari/Tanggal</label
            >
            <input
              type="date"
              id="hari_tanggal"
              name="hari_tanggal"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white [color-scheme:dark]"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="semester" class="font-medium text-gray-200"
              >Semester/Minggu Ke</label
            >
            <input
              type="text"
              id="semester"
              name="semester"
              placeholder="Misal: 1 / Minggu ke-2"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="tahun_ajaran" class="font-medium text-gray-200"
              >Tahun Ajaran</label
            >
            <input
              type="text"
              id="tahun_ajaran"
              name="tahun_ajaran"
              placeholder="Contoh: 2026/2027"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="kelas" class="font-medium text-gray-200"
              >Kelas/Kelompok Usia</label
            >
            <select
              id="kelas"
              name="kelas"
              class="p-2 rounded bg-gray-800 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
              <option value="">-- Pilih Kelas/Kelompok Usia --</option>
              <option value="Kelompok A (4-5 Tahun)">
                Kelompok A (4-5 Tahun)
              </option>
              <option value="Kelompok B (5-6 Tahun)">
                Kelompok B (5-6 Tahun)
              </option>
            </select>
          </div>

          <div class="flex flex-col gap-1">
            <label for="alokasi_waktu" class="font-medium text-gray-200"
              >Alokasi Waktu</label
            >
            <input
              type="text"
              id="alokasi_waktu"
              name="alokasi_waktu"
              placeholder="Misal: 40 menit"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label for="model_pembelajaran" class="font-medium text-gray-200">Model Pembelajaran</label>
            <div class="flex gap-2">
              <select
                id="model_pembelajaran"
                name="model_pembelajaran"
                class="flex-1 p-2 rounded bg-gray-800 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                onchange="handleModelChange()"
              >
                <option value="">-- Pilih Model Pembelajaran --</option>
                <option value="Project-Based Learning (PjBL)">Project-Based Learning (PjBL)</option>
                <option value="Problem-Based Learning (PBL)">Problem-Based Learning (PBL)</option>
                <option value="Inquiry & Discovery Learning">Inquiry & Discovery Learning</option>
                <option value="Pembelajaran Berdiferensiasi">Pembelajaran Berdiferensiasi</option>
                <option value="Flipped Classroom">Flipped Classroom</option>
                <option value="Game-Based Learning & Gamification">Game-Based Learning & Gamification</option>
                <option value="Cooperative Learning (Jigsaw, TPS)">Cooperative Learning (Jigsaw, TPS)</option>
                <option value="__custom__">+ Tambah Custom</option>
              </select>
              <button
                type="button"
                id="btn_add_custom_model"
                onclick="showAddCustomModel()"
                class="px-4 py-2 rounded bg-blue-500 hover:bg-blue-600 text-white font-semibold transition-colors focus:outline-none hidden"
                title="Tambah model custom"
              >
                +
              </button>
            </div>
            <div id="custom_model_container" class="hidden flex gap-2">
              <input
                type="text"
                id="custom_model_input"
                placeholder="Masukkan nama model (mis: Blended Learning)"
                class="flex-1 p-2 text-sm rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
              <button
                type="button"
                onclick="saveCustomModel()"
                class="px-3 py-2 text-sm rounded bg-green-500 hover:bg-green-600 text-white font-semibold transition-colors focus:outline-none"
              >
                Simpan
              </button>
              <button
                type="button"
                onclick="cancelCustomModel()"
                class="px-3 py-2 text-sm rounded bg-gray-600 hover:bg-gray-700 text-white font-semibold transition-colors focus:outline-none"
              >
                Batal
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-1">
            <label for="tema_subtema" class="font-medium text-gray-200"
              >Tema/Sub-Tema</label
            >
            <input
              type="text"
              id="tema_subtema"
              name="tema_subtema"
              placeholder="Misal: Diriku / Tubuhku"
              class="p-2 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>

          <div class="flex flex-col gap-1 md:col-span-2">
            <label for="tujuan_pembelajaran" class="font-medium text-gray-200"
              >Tujuan Pembelajaran</label
            >
            <div class="relative w-full">
              <textarea
                id="tujuan_pembelajaran"
                name="tujuan_pembelajaran"
                rows="4"
                placeholder="Tuliskan tujuan pembelajaran di sini..."
                class="w-full p-2 pr-10 rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-y"
              ></textarea>
              <button
                type="button"
                onclick="requestRecommendation()"
                class="absolute bottom-2 right-2 p-1.5 text-white rounded outline-none focus:ring-2 focus:ring-blue-400 transition-colors hover:cursor-pointer"
                title="Generate dengan AI"
                id="btn_recommendation"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  stroke="currentColor"
                  class="w-5 h-5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
                  />
                </svg>
              </button>
            </div>
          </div>

          <div class="flex flex-col gap-2 mt-2 md:col-span-2">
            <button
              type="button"
              id="btn_toggle_advance"
              onclick="toggleAdvanceOptions()"
              class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors w-fit focus:outline-none"
            >
              <svg
                id="icon_advance_chevron"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="w-5 h-5 transition-transform duration-200"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                  clip-rule="evenodd"
                />
              </svg>
              Tampilkan Opsi Lanjutan
            </button>
            <div
              id="advance_options_container"
              class="hidden flex-col gap-4 p-4 mt-2 bg-black/30 rounded-lg border border-gray-700"
            >
              <!-- Custom Prompt Section -->
              <div class="flex flex-col gap-1">
                <label
                  for="custom_prompt"
                  class="font-medium text-gray-200 text-sm"
                  >Instruksi Tambahan (Opsional AI)</label
                >
                <textarea
                  id="custom_prompt"
                  name="custom_prompt"
                  rows="2"
                  placeholder="Misal: Buatkan juga referensi lagu anak-anak yang cocok."
                  class="w-full p-2 text-sm rounded bg-black/20 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-y"
                ></textarea>
              </div>
            </div>
          </div>

          <button
            type="submit"
            id="btn_generate"
            class="mt-4 md:col-span-2 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded transition duration-200"
          >
            Buat RPP
          </button>
        </form>
      </div>

      <div
        class="flex-1 overflow-auto w-full h-full bg-white/10 p-6 rounded-lg border border-gray-600 text-white"
        id="preview_container"
      >
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-bold" id="preview_title">Preview RPP</h2>
          <button
            type="button"
            id="btn_download"
            onclick="downloadRPP()"
            class="hidden bg-green-500 hover:bg-green-600 text-white font-semibold py-1.5 px-4 rounded transition duration-200"
          >
            Download Word (.docx)
          </button>
        </div>
        <div class="prose prose-invert" id="preview_content">
          <p class="text-gray-500">
            Isi formulir untuk melihat preview RPP di sini.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/lib/marked.umd.js"></script>

<%- include('js/home') %>
