        'Puzzle Rumah Sederhana (Penalaran Kritis, Kemandirian). Anak menyusun puzzle kayu/karton berbentuk rumah sederhana (2-3 potong); guru membantu mengidentifikasi atap, dinding, dan pintu saat anak menyusun.',
        'Menempel Stiker Bagian Rumah (Kreativitas, Komunikasi). Sketsa rumah sederhana digambar di kertas besar; anak menempelkan stiker atau gambar kecil (jendela, pintu, atap) pada tempat yang sesuai sambil menyebutkan nama dan fungsinya.',
        // Hari 4
        'Memasang Manik-Manik Sesuai Angka (Penalaran Kritis, Kreativitas). Cantelan baju disusun dengan angka di bawah setiap cantelan; anak memasang/mencatel manik-manik sebanyak angka yang tertulis di setiap cantelan.',
        'Rumah Warna-warni (Kreativitas, Keimanan dan Ketakwaan). Anak mewarnai gambar outline rumah sederhana menggunakan krayon besar; guru menyebutkan warna-warna yang digunakan; anak menunjuk bagian-bagian yang diwarnai.',
        'Rumah Boneka Sederhana (Kolaborasi, Komunikasi). Kotak kardus besar dijadikan "rumah boneka"; anak menghiasnya dengan krayon/spidol dan bermain dengan boneka di dalamnya sambil menyebutkan bagian dan fungsi ruangan.',
        // Hari 5
        'Mengurutkan Gambar Berdasarkan Ukuran (Penalaran Kritis, Kemandirian). Bentuk geometri (persegi/persegi panjang) digambar dalam berbagai ukuran, digunting; anak mengurutkan dari paling besar ke paling kecil, juga mengelompokkan warna dan bentuk.',
        'Masuk Rumah Besar-Kecil (Kesehatan, Komunikasi). Dua kotak kardus (besar dan kecil) dihias menyerupai rumah; anak masuk-keluar dari "rumah" kardus besar dan kecil; guru menjelaskan konsep besar-kecil sambil mendorong anak mengidentifikasi perbedaan.',
        'Rumah Piring Kertas (Kreativitas, Kolaborasi). Anak diberi piring kertas putih sebagai dasar "rumah"; menggambar/mewarnai atap di atas piring, menempelkan potongan kertas warna sebagai jendela dan pintu; diakhiri bermain rumah-rumahan dengan boneka kecil.',
      ],
    },
  ];

  // ─────────────────────────────────────────────────────────────────────────────
  // Helpers
  // ─────────────────────────────────────────────────────────────────────────────

  /**
   * Set value of a text/number/textarea input and fire both 'input' and 'change'.
   */
  const setFieldValue = (id, value) => {
    const el = document.getElementById(id);
    if (!el) return;
    el.value = value;
    el.dispatchEvent(new Event('input', { bubbles: true }));
    el.dispatchEvent(new Event('change', { bubbles: true }));
  };

  /**
   * Check/uncheck checkboxes matching a CSS selector.
   * @param {string} selector  - e.g. '.dpl-option'
   * @param {string[]} values  - array of values that should be checked
   */
  const setCheckboxGroup = (selector, values) => {
    document.querySelectorAll(selector).forEach((cb) => {
      const shouldBeChecked = values.some(
        (v) => cb.value.trim().toUpperCase().startsWith(v.trim().toUpperCase()),
      );
      cb.checked = shouldBeChecked;
      cb.dispatchEvent(new Event('change', { bubbles: true }));
    });
  };

  /**
   * Apply a MODUL_TEMPLATES entry to all form fields.
   */
  const applyTemplate = (templateId) => {
    const tpl = MODUL_TEMPLATES.find((t) => t.id === templateId);
    if (!tpl) return;

    // ── Metadata fields ────────────────────────────────────────────────────────
    if (tpl.jumlahAnak !== '') setFieldValue('jumlahAnak', tpl.jumlahAnak);
    setFieldValue('temaSubtema', tpl.temaSubtema);
    setFieldValue('tujuanPembelajaran', tpl.tujuanPembelajaran);
    setFieldValue('topikPembelajaran', tpl.topikPembelajaran);

    // ── Alokasi waktu ──────────────────────────────────────────────────────────
    // Set the two numeric inputs first, then trigger the combined handler.
    const aw1 = document.getElementById('alokasiWaktu1');
    const aw2 = document.getElementById('alokasiWaktu2');
    if (aw1) aw1.value = tpl.alokasiHari;
    if (aw2) aw2.value = tpl.alokasiJp;

    // handleAlokasiWaktuChange is exposed on window by js/home.ejs.
    // It both updates the hidden #alokasiWaktu field and re-renders
    // the dynamic kegiatan input fields synchronously.
    if (typeof window.handleAlokasiWaktuChange === 'function') {
      window.handleAlokasiWaktuChange();
    }

    // ── Checkboxes ─────────────────────────────────────────────────────────────
    setCheckboxGroup('.model-pembelajaran-option', tpl.modelPembelajaran);
    setCheckboxGroup('.elemen-cp-option', tpl.elemenCp);
    setCheckboxGroup('.dpl-option', tpl.dpl);

    // ── Kegiatan inputs ────────────────────────────────────────────────────────
    // The dynamic fields are now rendered; fill them in sequence.
    let kegiatanIdx = 0;
    for (let hari = 1; hari <= tpl.alokasiHari; hari += 1) {
      for (let jp = 1; jp <= tpl.alokasiJp; jp += 1) {
        const val = tpl.kegiatan[kegiatanIdx] ?? '';
        setFieldValue(`kegiatanHari${hari}Jp${jp}`, val);
        kegiatanIdx += 1;
      }
    }

    // ── Visual feedback ────────────────────────────────────────────────────────
    showTemplateToast(tpl);

    // Scroll to top of the form so user sees the filled fields.
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // ─────────────────────────────────────────────────────────────────────────────
  // Toast notification
  // ─────────────────────────────────────────────────────────────────────────────
  const showTemplateToast = (tpl) => {
    const existing = document.getElementById('template-toast');
    if (existing) existing.remove();

    const toast = document.createElement('div');
    toast.id = 'template-toast';
    toast.style.cssText = [
      'position:fixed',
      'bottom:1.5rem',
      'right:1.5rem',
      'z-index:9999',
      'display:flex',
      'align-items:center',
      'gap:0.75rem',
      'background:#4c1d95',
      'color:#fff',
      'padding:0.75rem 1.25rem',
      'border-radius:0.75rem',
      'font-size:0.875rem',
      'max-width:20rem',
      'animation:slideInToast 0.3s ease',
    ].join(';');

    toast.innerHTML = `
      <span style="font-size:1.4rem">${tpl.emoji}</span>
      <div>
        <div style="font-weight:700">${tpl.sublabel}</div>
        <div style="opacity:0.85;margin-top:2px">Template berhasil diterapkan</div>
      </div>
    `;

    // Inject keyframe once
    if (!document.getElementById('template-toast-style')) {
      const style = document.createElement('style');
      style.id = 'template-toast-style';
      style.textContent = `
        @keyframes slideInToast {
          from { opacity: 0; transform: translateY(1rem); }
          to   { opacity: 1; transform: translateY(0); }
        }
      `;
      document.head.appendChild(style);
    }

    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3500);
  };

  // ─────────────────────────────────────────────────────────────────────────────
  // Render template buttons
  // ─────────────────────────────────────────────────────────────────────────────
  const renderTemplateButtons = () => {
    const container = document.getElementById('templateButtonsContainer');
    if (!container) return;

    container.innerHTML = '';

    // Label
    const label = document.createElement('p');
    label.className = 'text-sm font-semibold text-violet-800 mb-2';
    container.appendChild(label);

    // Button grid
    const grid = document.createElement('div');
    grid.className = 'flex flex-wrap gap-2';
    container.appendChild(grid);

    MODUL_TEMPLATES.forEach((tpl) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.dataset.templateId = tpl.id;

      btn.className = [
        'inline-flex items-center gap-1.5',
        'rounded-lg border-2 border-violet-800/25',
        'bg-white px-3 py-1.5',
        'text-xs font-semibold text-violet-800',
        'transition-all duration-150',
        'hover:border-violet-700 hover:bg-violet-50 hover:shadow-sm',
        'active:scale-95',
        'cursor-pointer',
      ].join(' ');

      btn.innerHTML = `
        <span aria-hidden="true">${tpl.emoji}</span>
        <span>${tpl.sublabel}</span>
      `;

      btn.addEventListener('click', () => applyTemplate(tpl.id));
      grid.appendChild(btn);
    });

    // Reset / clear button
    const divider = document.createElement('div');
    divider.className = 'w-full border-t border-violet-800/10 my-1';
    grid.appendChild(divider);

    const resetBtn = document.createElement('button');
    resetBtn.type = 'button';
    resetBtn.className = [
      'inline-flex items-center gap-1.5',
      'rounded-lg border-2 border-red-200',
      'bg-white px-3 py-1.5',
      'text-xs font-semibold text-red-500',
      'transition-all duration-150',
      'hover:border-red-400 hover:bg-red-50',
      'active:scale-95',
      'cursor-pointer',
    ].join(' ');
    resetBtn.innerHTML = '<span aria-hidden="true">✕</span><span>Kosongkan semua field</span>';
    resetBtn.addEventListener('click', clearAllFields);
    grid.appendChild(resetBtn);
  };

  // ─────────────────────────────────────────────────────────────────────────────
  // Clear all form fields
  // ─────────────────────────────────────────────────────────────────────────────
  const CLEARABLE_IDS = [
    'namaPenyusun', 'namaSekolah', 'nip', 'fase', 'kelas', 'semester',
    'mingguKe', 'bulan', 'jumlahAnak', 'temaSubtema', 'tujuanPembelajaran', 'topikPembelajaran',
    'alokasiWaktu1', 'alokasiWaktu2',
  ];

  const clearAllFields = () => {
    CLEARABLE_IDS.forEach((id) => setFieldValue(id, ''));

    // Uncheck all checkbox groups
    ['model-pembelajaran-option', 'elemen-cp-option', 'dpl-option'].forEach((cls) => {
      document.querySelectorAll(`.${cls}`).forEach((cb) => {
        cb.checked = false;
        cb.dispatchEvent(new Event('change', { bubbles: true }));
      });
    });

    // Clear alokasi → triggers kegiatan fields to clear/re-render
    if (typeof window.handleAlokasiWaktuChange === 'function') {
      window.handleAlokasiWaktuChange();
    }
  };

  // ─────────────────────────────────────────────────────────────────────────────
  // Init — run after DOM is ready
  // ─────────────────────────────────────────────────────────────────────────────
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderTemplateButtons);
  } else {
    renderTemplateButtons();
  }

  // Expose applyTemplate globally (useful for testing or external calls)
  window.applyModulTemplate = applyTemplate;
</script>
