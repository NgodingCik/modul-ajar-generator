<script>
  const btnGenerate = document.getElementById("btn_generate");
  const btnDownload = document.getElementById("btn_download");
  const previewContent = document.getElementById("preview_content");
  const form = document.getElementById("form-rpp");
  const previewContainer = document.getElementById("preview_container");
  const resizeDivider = document.getElementById("resize_divider");

  let currentMarkdown = null;
  let rppObject = null;
  let isResizing = false;
  let previewHeight = 384;

  const BTN_CLASSES = {
    active: "flex-1 py-2 px-4 rounded font-semibold transition-colors bg-blue-500 text-white border border-blue-500 hover:bg-blue-600 focus:outline-none",
    inactive: "flex-1 py-2 px-4 rounded font-semibold transition-colors bg-gray-700 text-gray-300 border border-gray-600 hover:bg-gray-600 focus:outline-none"
  };

  const DEFAULT_MODELS = [
    { label: "Project-Based Learning (PjBL)", value: "Project-Based Learning (PjBL)" },
    { label: "Problem-Based Learning (PBL)", value: "Problem-Based Learning (PBL)" },
    { label: "Inquiry & Discovery Learning", value: "Inquiry & Discovery Learning" },
    { label: "Pembelajaran Berdiferensiasi", value: "Pembelajaran Berdiferensiasi" },
    { label: "Flipped Classroom", value: "Flipped Classroom" },
    { label: "Game-Based Learning & Gamification", value: "Game-Based Learning & Gamification" },
    { label: "Cooperative Learning (Jigsaw, TPS)", value: "Cooperative Learning (Jigsaw, TPS)" }
  ];

  function getCustomModels() {
    const stored = localStorage.getItem("customModels");
    return stored ? JSON.parse(stored) : [];
  }

  function saveCustomModelsToStorage(models) {
    localStorage.setItem("customModels", JSON.stringify(models));
  }

  function loadCustomModelsToDropdown() {
    const select = document.getElementById("model_pembelajaran");
    const customModels = getCustomModels();

    customModels.forEach(model => {
      const optionExists = Array.from(select.options).some(opt => opt.value === model);
      if (!optionExists) {
        const option = document.createElement("option");
        option.value = model;
        option.textContent = model;
        select.insertBefore(option, select.querySelector('option[value="__custom__"]'));
      }
    });
  }

  function initResizablePreview() {
    const isMobile = window.innerWidth < 768;

    if (!isMobile) {
      const savedWidth = localStorage.getItem("previewWidth");
      if (savedWidth) {
        previewContainer.style.width = savedWidth;
      }

      resizeDivider.addEventListener("mousedown", startResize);
    }
  }

  function startResize(e) {
    isResizing = true;
    const startX = e.clientX;
    const startWidth = previewContainer.offsetWidth;

    function onMouseMove(e) {
      if (!isResizing) return;
      const diff = e.clientX - startX;
      let newWidth = startWidth - diff;
      const minWidth = 300;
      const maxWidth = window.innerWidth - 400;

      newWidth = Math.max(minWidth, Math.min(maxWidth, newWidth));
      previewContainer.style.width = newWidth + "px";
      localStorage.setItem("previewWidth", newWidth + "px");
    }

    function onMouseUp() {
      isResizing = false;
      document.removeEventListener("mousemove", onMouseMove);
      document.removeEventListener("mouseup", onMouseUp);
    }

    document.addEventListener("mousemove", onMouseMove);
    document.addEventListener("mouseup", onMouseUp);
  }

  function showPreview() {
    previewContainer.style.display = "flex";
    previewContainer.style.flexDirection = "column";
    document.getElementById("preview_backdrop").classList.remove("hidden");
    previewHeight = 384;
    localStorage.setItem("previewVisible", "true");
    updatePreviewToggleButton();
  }

  function hidePreview() {
    previewContainer.style.display = "none";
    document.getElementById("preview_backdrop").classList.add("hidden");
    localStorage.setItem("previewVisible", "false");
    updatePreviewToggleButton();
  }

  function togglePreviewMobile() {
    const isMobile = window.innerWidth < 768;
    if (!isMobile) return;

    if (previewContainer.style.display === "none") {
      showPreview();
    } else {
      hidePreview();
    }
  }

  function updatePreviewToggleButton() {
    const toggleBtn = document.getElementById("btn_preview_toggle");
    const toggleIcon = document.getElementById("preview_toggle_icon");

    if (!toggleBtn || !toggleIcon) return;

    if (previewContainer.style.display === "none") {
      toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />';
      toggleBtn.title = "Show preview";
    } else {
      toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />';
      toggleBtn.title = "Hide preview";
    }
  }

  function minimizePreview() {
    const isMobile = window.innerWidth < 768;
    previewHeight = 60;
    if (isMobile) {
      previewContainer.style.height = "60px";
      document.getElementById("preview_backdrop").classList.add("hidden");
    }
    const prose = previewContainer.querySelector(".prose");
    if (prose) prose.style.display = "none";

    const minimizeBtn = document.getElementById("btn_preview_minimize");
    minimizeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" /></svg>';
    minimizeBtn.title = "Expand";
    minimizeBtn.setAttribute("onclick", "expandPreview()");

    document.getElementById("btn_download").style.display = "none";
    localStorage.setItem("previewHeight", "60");
  }

  function expandPreview() {
    const isMobile = window.innerWidth < 768;
    previewHeight = 384;
    if (isMobile) {
      previewContainer.style.height = "80vh";
      document.getElementById("preview_backdrop").classList.remove("hidden");
    } else {
      previewContainer.style.height = "";
    }
    const prose = previewContainer.querySelector(".prose");
    if (prose) prose.style.display = "block";
    if (currentMarkdown) {
      document.getElementById("btn_download").style.display = "inline-block";
    }

    const minimizeBtn = document.getElementById("btn_preview_minimize");
    minimizeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 20.25l-7.5-6.75M19.5 6.75L12 13.5l-7.5-6.75" /></svg>';
    minimizeBtn.title = "Minimize";
    minimizeBtn.setAttribute("onclick", "minimizePreview()");

    localStorage.setItem("previewHeight", "384");
  }

  window.addEventListener("DOMContentLoaded", () => {
    loadCustomModelsToDropdown();
    initResizablePreview();

    const savedVisible = localStorage.getItem("previewVisible");
    const savedHeight = localStorage.getItem("previewHeight");

    if (savedVisible === "false" && window.innerWidth < 768) {
      hidePreview();
    }

    if (savedHeight === "60" && window.innerWidth < 768) {
      minimizePreview();
    }

    updatePreviewToggleButton();

    const savedData = localStorage.getItem("rppFormData");
    if (savedData) {
      const formData = JSON.parse(savedData);
      for (const key in formData) {
        const input = document.querySelector(`[name="${key}"]`);
        if (input) input.value = formData[key];
      }
    }

    const savedMarkdown = localStorage.getItem("rppPreviewMarkdown");
    if (savedMarkdown) {
      currentMarkdown = savedMarkdown;
      previewContent.innerHTML = marked.parse(savedMarkdown);
      btnDownload.classList.remove("hidden");
      showPreview();
      expandPreview();
    }

    const savedRppObject = localStorage.getItem("rppPreviewObject");
    if (savedRppObject) {
      rppObject = JSON.parse(savedRppObject);
    }
  });

  window.addEventListener("resize", () => {
    initResizablePreview();
  });

  form.addEventListener("input", () => {
    const formData = new FormData(form);
    const dataToSave = {};
    formData.forEach((value, key) => {
      dataToSave[key] = value;
    });
    localStorage.setItem("rppFormData", JSON.stringify(dataToSave));
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    localStorage.removeItem("rppPreviewMarkdown");
    localStorage.removeItem("rppPreviewObject");
    currentMarkdown = null;
    rppObject = null;
    previewContent.innerHTML =
      '<p class="text-blue-400 animate-pulse">Sedang menghasilkan RPP, harap tunggu sebentar...</p>';
    btnDownload.classList.add("hidden");
    showPreview();
    expandPreview();

    const formData = new FormData(e.target);
    const dataInput = {};
    formData.forEach((value, key) => {
      dataInput[key] = value;
    });

    try {
      btnGenerate.disabled = true;
      btnGenerate.classList.add("animate-pulse");
      btnGenerate.textContent = "Sedang Membuat RPP...";
      previewContent.innerHTML =
        '<p class="text-blue-400 animate-pulse">Sedang menghasilkan RPP menggunakan AI, harap tunggu sebentar...</p>';

      const response = await fetch("<%= BASE_URL %>/api/generate-rpp", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ data: dataInput }),
      });

      const data = await response.json();

      if (data.rpp) {
        currentMarkdown = data.rpp;
        rppObject = data.obj;
        previewContent.innerHTML = marked.parse(data.rpp);
        localStorage.setItem("rppPreviewMarkdown", data.rpp);
        localStorage.setItem("rppPreviewObject", JSON.stringify(data.obj));
        btnDownload.classList.remove("hidden");
      } else {
        previewContent.innerHTML =
          '<p class="text-red-500">Gagal menghasilkan RPP.</p>';
      }
    } catch (error) {
      console.error("Error generating RPP:", error);
      previewContent.innerHTML =
        '<p class="text-red-500">Terjadi kesalahan pada server saat menghasilkan RPP.</p>';
    } finally {
      btnGenerate.disabled = false;
      btnGenerate.classList.remove("animate-pulse");
      btnGenerate.textContent = "Buat RPP";
    }
  });

  async function downloadRPP() {
    if (!currentMarkdown) return;

    const btnDownloadEl = document.getElementById("btn_download");
    const originalText = btnDownloadEl.textContent;
    btnDownloadEl.disabled = true;
    btnDownloadEl.textContent = "Mengunduh...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    data.kelas = {
      "kelompok_a": "Kelompok A (4-5 Tahun)",
      "kelompok_b": "Kelompok B (5-6 Tahun)"
    }[data.kelas] || data.kelas;

    const mergedData = { ...data, ...rppObject };

    try {
      const response = await fetch("/api/download-rpp", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ rppObject: mergedData, md: currentMarkdown }),
      });

      if (!response.ok) throw new Error("Failed to download RPP");

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "RPP.docx";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      window.URL.revokeObjectURL(url);
    } catch (error) {
      console.error("Error downloading RPP:", error);
      alert("Gagal mengunduh RPP. Silakan coba lagi.");
    } finally {
      btnDownloadEl.disabled = false;
      btnDownloadEl.textContent = originalText;
    }
  }

  function requestRecommendation() {
    try {
      const button = document.getElementById("btn_recommendation");
      const submitButton = document.getElementById("btn_generate");
      const inputField = document.getElementById("tujuan_pembelajaran");

      if (!inputField.value) {
        alert("Silakan isi tujuan pembelajaran terlebih dahulu!");
        return;
      }

      button.classList.add("animate-pulse");
      button.disabled = true;
      inputField.disabled = true;
      submitButton.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      fetch("/api/recommendation", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt: inputField.value, data }),
      })
        .then((response) => response.json())
        .then((result) => {
          if (result.recommendation) {
            inputField.value = result.recommendation;
          } else {
            alert("Rekomendasi tidak tersedia. Silakan coba lagi nanti.");
          }
        })
        .catch((error) => {
          console.error("Error fetching recommendation:", error);
          alert("Terjadi kesalahan saat mengambil rekomendasi. Silakan coba lagi.");
        })
        .finally(() => {
          button.classList.remove("animate-pulse");
          button.disabled = false;
          inputField.disabled = false;
          submitButton.disabled = false;
        });
    } catch (error) {
      console.error("Error in requestRecommendation:", error);
      alert("Terjadi kesalahan. Silakan coba lagi.");
    }
  }

  function handleModelChange() {
    const select = document.getElementById("model_pembelajaran");
    const container = document.getElementById("custom_model_container");
    const btn = document.getElementById("btn_add_custom_model");

    if (select.value === "__custom__") {
      showAddCustomModel();
    } else {
      container.classList.add("hidden");
      btn.classList.add("hidden");
      select.value = select.options[select.selectedIndex].value;
    }
  }

  function showAddCustomModel() {
    const container = document.getElementById("custom_model_container");
    const input = document.getElementById("custom_model_input");
    const select = document.getElementById("model_pembelajaran");

    select.value = "__custom__";
    container.classList.remove("hidden");
    input.focus();
  }

  function saveCustomModel() {
    const input = document.getElementById("custom_model_input");
    const select = document.getElementById("model_pembelajaran");
    const modelName = input.value.trim();

    if (!modelName) {
      alert("Silakan masukkan nama model pembelajaran!");
      return;
    }

    const customModels = getCustomModels();
    if (!customModels.includes(modelName)) {
      customModels.push(modelName);
      saveCustomModelsToStorage(customModels);

      const option = document.createElement("option");
      option.value = modelName;
      option.textContent = modelName;
      select.insertBefore(option, select.querySelector('option[value="__custom__"]'));
    }

    select.value = modelName;
    cancelCustomModel();
  }

  function cancelCustomModel() {
    const container = document.getElementById("custom_model_container");
    const input = document.getElementById("custom_model_input");
    const select = document.getElementById("model_pembelajaran");

    container.classList.add("hidden");
    input.value = "";
    select.value = "";
  }

  function pilihTipeRPP(tipe) {
    document.getElementById("tipe_rpp").value = tipe;
    const btnRpph = document.getElementById("btn_rpph");
    const btnRppm = document.getElementById("btn_rppm");

    if (tipe === "rpph") {
      btnRpph.className = BTN_CLASSES.active;
      btnRppm.className = BTN_CLASSES.inactive;
    } else {
      btnRppm.className = BTN_CLASSES.active;
      btnRpph.className = BTN_CLASSES.inactive;
    }
  }

  function toggleAdvanceOptions() {
    const container = document.getElementById("advance_options_container");
    const icon = document.getElementById("icon_advance_chevron");
    const isHidden = container.classList.contains("hidden");

    if (isHidden) {
      container.classList.remove("hidden");
      container.classList.add("flex");
      icon.style.transform = "rotate(-180deg)";
    } else {
      container.classList.add("hidden");
      container.classList.remove("flex");
      icon.style.transform = "rotate(0deg)";
    }
  }
</script>
