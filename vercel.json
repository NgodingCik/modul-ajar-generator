{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/index.js",
      "use": "@vercel/node",
      "config": {
        "bundle": true,
        "includeFiles": [
          "resources/**",
          "public/**",
          "context/**"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/apps/web/index.js"
    }
  ]
}