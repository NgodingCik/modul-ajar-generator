{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node",
      "config": {
        "bundle": false,
        "includeFiles": [
          "src/**",
          "context/**",
          "public/**",
          "assets/**",
          "node_modules/openai/**",
          "node_modules/consola/**",
          "node_modules/dotenv/**",
          "node_modules/express/**",
          "node_modules/ejs/**",
          "node_modules/docx/**",
          "node_modules/@dqbd/**",
          "node_modules/express-rate-limit/**",
          "node_modules/helmet/**"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/src/index.js"
    }
  ]
}